    "settings.privacy.helper" : {"localizations":{"de":{"stringUnit":{"state":"translated","value":"Sie können jederzeit widersprechen. Fotos, Videos, Standort, Projektnamen und persönliche Kennungen werden nicht gesendet."}},"en":{"stringUnit":{"state":"translated","value":"You can opt out at any time. Photos, videos, location, project names, and personal identifiers are not sent."}},"es":{"stringUnit":{"state":"translated","value":"Puedes desactivarlo en cualquier momento. No se envían fotos, vídeos, ubicación, nombres de proyectos ni identificadores personales."}},"fr":{"stringUnit":{"state":"translated","value":"Vous pouvez vous désinscrire à tout moment. Les photos, vidéos, la localisation, les noms de projets et les identifiants personnels ne sont pas envoyés."}},"pt-BR":{"stringUnit":{"state":"translated","value":"Você pode sair a qualquer momento. Fotos, vídeos, localização, nomes de projetos e identificadores pessoais não são enviados."}},"ru":{"stringUnit":{"state":"translated","value":"Вы можете отказаться в любое время. Фото, видео, геопозиция, названия проектов и личные идентификаторы не отправляются."}}}},
