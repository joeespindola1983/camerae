# Copy to Release.local.env and fill only the values needed by your destination.
# Release.local.env is ignored by Git.

APPLE_TEAM_ID=

# App Store Connect upload (API key file already stored locally).
APP_STORE_CONNECT_KEY_PATH=
APP_STORE_CONNECT_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=

# Firebase App Distribution. FIREBASE_TOKEN is optional after `firebase login`.
FIREBASE_APP_ID=
FIREBASE_PROJECT_ID=
FIREBASE_GROUPS=testers
# FIREBASE_TOKEN=
